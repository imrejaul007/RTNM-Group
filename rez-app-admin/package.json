{
  "name": "rez-admin",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start --port 8083",
    "start:clear": "node scripts/clear-cache.js && expo start --port 8083",
    "clear-cache": "node scripts/clear-cache.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web --port 8083",
    "build:web": "expo export --platform web",
    "eas:configure": "eas build:configure",
    "build:dev:ios": "eas build --platform ios --profile development",
    "build:dev:android": "eas build --platform android --profile development",
    "build:preview:ios": "eas build --platform ios --profile preview",
    "build:preview:android": "eas build --platform android --profile preview",
    "build:prod:ios": "eas build --platform ios --profile production",
    "build:prod:android": "eas build --platform android --profile production",
    "build:prod:all": "eas build --platform all --profile production",
    "submit:ios": "eas submit --platform ios --profile production",
    "submit:android": "eas submit --platform android --profile production",
    "test": "jest --no-coverage",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch --no-coverage",
    "prepare": "husky",
    "format": "prettier --write 'app/**/*.ts' 'app/**/*.tsx'",
    "lint": "eslint 'app/**/*.{ts,tsx}' --max-warnings 0",
    "lint:fix": "eslint 'app/**/*.{ts,tsx}' --fix"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.1.0",
    "@hookform/resolvers": "^5.2.2",
    "@rez/shared": "file:../rez-shared",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/datetimepicker": "^8.4.1",
    "@react-native-community/netinfo": "^11.4.1",
    "@react-navigation/bottom-tabs": "^7.4.6",
    "@react-navigation/native": "^7.1.17",
    "@sentry/react-native": "^5.22.0",
    "@tanstack/react-query": "^5.85.3",
    "axios": "^1.15.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "date-fns": "^4.1.0",
    "expo": "~53.0.26",
    "expo-constants": "~17.1.7",
    "expo-font": "~13.3.2",
    "expo-haptics": "^14.1.4",
    "expo-image": "~2.4.0",
    "expo-image-picker": "~16.1.4",
    "expo-linear-gradient": "~14.1.5",
    "expo-linking": "~7.1.7",
    "expo-notifications": "^0.31.4",
    "expo-router": "~5.1.4",
    "expo-secure-store": "~14.2.4",
    "expo-status-bar": "~2.2.3",
    "expo-updates": "~0.28.18",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.66.0",
    "react-native": "0.79.5",
    "react-native-animatable": "^1.4.0",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-web": "^0.20.0",
    "socket.io-client": "^4.8.1",
    "tslib": "^2.8.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@eslint/js": "^9.0.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.0.10",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "buffer": "^6.0.3",
    "crypto-browserify": "^3.12.1",
    "husky": "^9.0.11",
    "jest": "^29.7.0",
    "jest-expo": "~53.0.5",
    "lint-staged": "^15.2.2",
    "prettier": "^3.2.5",
    "process": "^0.11.10",
    "stream-browserify": "^3.0.0",
    "ts-jest": "^29.4.6",
    "typescript": "~5.8.3",
    "util": "^0.12.5"
  },
  "private": true,
  "overrides": {
    "@xmldom/xmldom": ">=0.9.0",
    "undici": ">=7.0.0",
    "socket.io-parser": ">=4.2.6",
    "handlebars": ">=4.7.9",
    "lodash": ">=4.17.24",
    "minimatch": ">=3.1.4",
    "picomatch": ">=2.3.1",
    "node-forge": ">=1.3.4",
    "follow-redirects": ">=1.15.12"
  },
  "lint-staged": {
    "app/**/*.ts": [
      "prettier --write"
    ],
    "app/**/*.tsx": [
      "prettier --write"
    ]
  }
}
