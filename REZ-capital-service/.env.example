# Capital Service - Environment Variables

# =============================================================================
# REQUIRED VARIABLES
# =============================================================================

INTERNAL_SERVICE_TOKEN=your-secure-random-token-here
INTERNAL_SERVICE_TOKENS_JSON={"merchant-service":"token1","finance-service":"token2"}

# =============================================================================
# OPTIONAL VARIABLES
# =============================================================================

PORT=3005
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/rez-capital
ALLOWED_ORIGINS=https://rezapp.com,https://www.rezapp.com
LOG_LEVEL=info

# =============================================================================
# SECURITY NOTES
# =============================================================================
# Generate token: openssl rand -hex 32
