# Server Configuration
PORT=3005
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/rez-capital

# Logging
LOG_LEVEL=info

# Callback URL for partner webhooks
CALLBACK_BASE_URL=https://your-domain.com

# Capital Float Configuration
CAPITAL_FLOAT_API_URL=https://api.capitalfloat.com/v2
CAPITAL_FLOAT_API_KEY=your_api_key
CAPITAL_FLOAT_ENABLED=true
CAPITAL_FLOAT_WEBHOOK_SECRET=your_webhook_secret

# PineLabs Configuration
PINELABS_API_URL=https://api.pinelabs.com/v1
PINELABS_API_KEY=your_api_key
PINELABS_MERCHANT_ID=your_merchant_id
PINELABS_ENABLED=false
PINELABS_WEBHOOK_SECRET=your_webhook_secret

# Indifi Configuration
INDIFI_API_URL=https://api.indifi.com/v1
INDIFI_API_KEY=your_api_key
INDIFI_CLIENT_ID=your_client_id
INDIFI_ENABLED=false
INDIFI_WEBHOOK_SECRET=your_webhook_secret

# LendingKart Configuration
LENDINGKART_API_URL=https://api.lendingkart.com/v2
LENDINGKART_API_KEY=your_api_key
LENDINGKART_ENABLED=false
LENDINGKART_WEBHOOK_SECRET=your_webhook_secret
