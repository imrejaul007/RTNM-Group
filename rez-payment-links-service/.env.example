# Server Configuration
PORT=4018
NODE_ENV=development
BASE_URL=https://pay.rezpay.in

# API Authentication
API_KEY=your-api-key-here
MERCHANT_ID=your-merchant-id

# UPI Provider Configuration
UPI_PROVIDER=razorpay
UPI_API_URL=https://api.razorpay.com/v1
UPI_API_KEY=your-upi-api-key
UPI_API_SECRET=your-upi-api-secret

# Webhook Configuration
WEBHOOK_SECRET=your-webhook-secret

# Email Configuration
EMAIL_FROM=noreply@rezpay.in
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password

# Logging
LOG_LEVEL=info

# CORS
CORS_ORIGIN=*
