# ===========================================
# NeXha - Environment Configuration
# ===========================================

# Node Environment
NODE_ENV=development

# Service Ports
PORT_DISTRIBUTION=4300
PORT_FRANCHISE=4310
PORT_PROCUREMENT=4320
PORT_MANUFACTURING=4330
PORT_CONNECTOR=4399
PORTAL_PORT=4388

# ===========================================
# Database - MongoDB
# ===========================================
MONGODB_URI=mongodb://localhost:27017/nexha
# For production:
# MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/nexha

# ===========================================
# Database - PostgreSQL (for specific services)
# ===========================================
DATABASE_URL=postgresql://postgres:password@localhost:5432/nexha

# ===========================================
# RABTUL Auth Service
# ===========================================
AUTH_SERVICE_URL=https://rez-auth-service.onrender.com
# For local development:
# AUTH_SERVICE_URL=http://localhost:4002

# Internal Service Token (service-to-service auth)
INTERNAL_SERVICE_TOKEN=your-internal-service-token

# ===========================================
# REZ Ecosystem Services
# ===========================================
REZ_MERCHANT_URL=http://localhost:4003
REZ_INTELLIGENCE_URL=http://localhost:4018
RTNM_FINANCE_URL=http://localhost:4004
NEXTABIZZ_URL=http://localhost:3000

# ===========================================
# Redis Cache
# ===========================================
REDIS_URL=redis://localhost:6379

# ===========================================
# Webhook Secrets
# ===========================================
WEBHOOK_SECRET=your-webhook-secret
REZ_MERCHANT_WEBHOOK_SECRET=your-merchant-webhook-secret
NEXTABIZZ_WEBHOOK_SECRET=your-nextabizz-webhook-secret

# ===========================================
# External Services
# ===========================================

# SMS (for OTPs and notifications)
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE_NUMBER=+1234567890

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Storage (for documents)
STORAGE_PROVIDER=cloudinary
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# ===========================================
# Payment & Finance
# ===========================================
RAZORPAY_KEY_ID=your-razorpay-key
RAZORPAY_KEY_SECRET=your-razorpay-secret
STRIPE_SECRET_KEY=sk_test_xxx

# ===========================================
# Observability
# ===========================================
SENTRY_DSN=https://xxx@sentry.io/xxx
SENTRY_TRACES_SAMPLE_RATE=0.1

# ===========================================
# Rate Limiting
# ===========================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ===========================================
# CORS
# ===========================================
CORS_ORIGIN=http://localhost:3000,http://localhost:4388

# ===========================================
# Feature Flags
# ===========================================
ENABLE_AI_FEATURES=true
ENABLE_AUTO_RFQ=true
ENABLE_SCORE_UPDATES=true
