# =============================================================================
# ReZ Admin Service - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values
# NEVER commit .env files to version control
# =============================================================================

# =============================================================================
# SECTION 1: REQUIRED VARIABLES (Service won't start without these)
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------

# MongoDB connection string
# Format: mongodb://username:password@host:port/database?options
# Example: mongodb://localhost:27017/admin_service
MONGODB_URI=mongodb://localhost:27017/admin_service

# -----------------------------------------------------------------------------
# Authentication & Security
# -----------------------------------------------------------------------------

# JWT signing secret - MUST be cryptographically strong (minimum 64 characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# WARNING: Changing this will invalidate all existing tokens
JWT_SECRET=your-super-secret-jwt-key-at-least-64-characters-long-here

# Default admin credentials (used only when no admins exist in the database)
# IMPORTANT: Change these immediately after first login

# Default admin email address
DEFAULT_ADMIN_EMAIL=admin@rez.money

# Default admin password (minimum 12 characters, no weak patterns)
# Must contain: uppercase, lowercase, numbers, special characters
# Generate a strong password and store it securely
DEFAULT_ADMIN_PASSWORD=ChangeMe123!@#SecurePassword

# Internal API key for REE service communication
# Used for service-to-service authentication
RZ_ADMIN_KEY=your-internal-api-key-for-ree-service

# Internal service token for RABTUL auth service communication
# Used to authenticate requests to other RABTUL services
INTERNAL_SERVICE_TOKEN=your-internal-service-token

# =============================================================================
# SECTION 2: PRODUCTION REQUIREMENTS (Must be set for production deployment)
# =============================================================================

# Comma-separated list of allowed CORS origins
# Example: https://admin.rez.money,https://dashboard.rez.money
# Must include the exact origin(s) that will make requests to this service
ALLOWED_ORIGINS=https://admin.rez.money,https://dashboard.rez.money

# RABTUL Auth Service URL for token verification
# This is the canonical auth service for the ReZ ecosystem
AUTH_SERVICE_URL=https://rez-auth-service.onrender.com

# =============================================================================
# SECTION 3: OPTIONAL VARIABLES (Service works with defaults if not set)
# =============================================================================

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------

# Server port (default: 4003)
# PORT=4003

# Node environment (development, production, test)
# Set to 'production' in production deployments
NODE_ENV=development

# -----------------------------------------------------------------------------
# Caching & Sessions
# -----------------------------------------------------------------------------

# Redis URL for caching and session management
# Format: redis://username:password@host:port
# Example: redis://localhost:6379
# REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------

# Sentry DSN for error tracking and monitoring
# Format: https://{key}@{org}.sentry.io/{project}
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project

# Logging level (debug, info, warn, error)
# LOG_LEVEL=info

# =============================================================================
# SECTION 4: SECURITY NOTES
# =============================================================================
#
# PASSWORD REQUIREMENTS:
# - Minimum 12 characters for admin passwords
# - Must include uppercase, lowercase, numbers, and special characters
# - Must NOT contain weak patterns (test, dev, changeme, password, admin)
#
# JWT_SECRET REQUIREMENTS:
# - Minimum 64 characters recommended
# - Must be cryptographically random (use the generator command above)
# - Must NOT be used in multiple environments
#
# PRODUCTION CHECKLIST:
# [ ] Change all default passwords immediately
# [ ] Use a secrets manager (AWS Secrets Manager, HashiCorp Vault, etc.)
# [ ] Enable HTTPS/TLS
# [ ] Set NODE_ENV=production
# [ ] Configure ALLOWED_ORIGINS with exact production origins
# [ ] Enable Redis for session management
# [ ] Set up Sentry for error tracking
# [ ] Rotate secrets regularly (every 90 days recommended)
#
# NEVER:
# - Commit .env files to version control
# - Use weak or default passwords
# - Share secrets via email or chat
# - Log sensitive values (passwords, tokens, keys)
#
# =============================================================================
