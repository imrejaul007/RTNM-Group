{
  "name": "@rez/dooh-shared",
  "version": "1.0.0",
  "description": "DOOH - Digital Out of Home Advertising Network - Shared Types & Utilities",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    },
    "./schemas": {
      "types": "./dist/schemas.d.ts",
      "default": "./dist/schemas.js"
    },
    "./state-machines": {
      "types": "./dist/state-machines.d.ts",
      "default": "./dist/state-machines.js"
    },
    "./money": {
      "types": "./dist/money.d.ts",
      "default": "./dist/money.js"
    }
  },
  "files": [
    "dist/",
    "src/"
  ],
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "dooh",
    "digital-out-of-home",
    "advertising",
    "screen-network",
    "shared-types",
    "typescript"
  ],
  "author": "ReZ App",
  "license": "MIT",
  "peerDependencies": {
    "zod": ">=3.0.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "zod": "^3.22.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
