# REZ Secrets Manager - Environment Configuration

# Server Configuration
PORT=4033
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/rez-secrets-vault

# Encryption Keys (REQUIRED - Generate with: openssl rand -hex 32)
VAULT_MASTER_KEY=your-master-key-here
ENCRYPTION_KEY=your-encryption-key-here

# Internal Service Authentication
INTERNAL_SERVICE_TOKEN=your-internal-service-token

# Rate Limiting
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX=100

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Rotation Scheduler
ROTATION_CRON=0 */15 * * * *

# Logging
LOG_LEVEL=info
LOG_DIR=./logs

# Audit Retention (days)
AUDIT_RETENTION_DAYS=90

# Service Registration
SERVICE_REGISTRATION_ENABLED=true
