    {
      "name": "Identity Service",
      "item": [
        {
          "name": "Create Identity",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Identity created successfully', function() {",
                  "    pm.response.to.have.status(201);",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.success).to.eql(true);",
                  "    pm.expect(jsonData.data.identityId).to.be.a('string');",
                  "    pm.collectionVariables.set('identityId', jsonData.data.identityId);",
                  "    pm.collectionVariables.set('clusterId', jsonData.data.clusterId);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-Internal-Token",
                "value": "{{internalToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"type\": \"app_user\",\n    \"identifier\": \"test@example.com\",\n    \"metadata\": {\n        \"source\": \"web\",\n        \"platform\": \"ios\",\n        \"appVersion\": \"1.0.0\"\n    },\n    \"privacySettings\": {\n        \"trackingEnabled\": true,\n        \"marketingConsent\": false,\n        \"analyticsConsent\": true\n    }\n}"
            },
            "url": {
              "raw": "{{identityServiceUrl}}/api/v1/identity",
              "host": ["{{identityServiceUrl}}"],
              "path": ["api", "v1", "identity"]
            }
          }
        },
        {
          "name": "Get Identity by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Internal-Token",
                "value": "{{internalToken}}"
              }
            ],
            "url": {
              "raw": "{{identityServiceUrl}}/api/v1/identity/{{identityId}}",
              "host": ["{{identityServiceUrl}}"],
