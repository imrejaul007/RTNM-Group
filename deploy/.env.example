# RTNM-Group Environment Variables Template
# Copy to .env and fill in values

# ============================================
# Authentication
# ============================================
JWT_SECRET=your-jwt-secret-min-32-chars
INTERNAL_SERVICE_TOKENS_JSON={"admin-panel":"your-admin-token","payment-service":"your-payment-token"}

# ============================================
# Identity Service
# ============================================
IDENTITY_SALT=your-secure-random-salt-min-32-chars

# ============================================
# Ops Dashboard
# ============================================
OPS_ADMIN_TOKEN=your-ops-admin-token

# ============================================
# NBFC Partner API Keys
# ============================================
CAPITAL_FLOAT_API_KEY=your-capital-float-api-key
CAPITAL_FLOAT_API_URL=https://api.capitalfloat.com/v2
PINELABS_API_KEY=your-pinelabs-api-key
INDIFI_API_KEY=your-indifi-api-key
LENDINGKART_API_KEY=your-lendingkart-api-key

# ============================================
# External Services
# ============================================
AUTH_SERVICE_URL=https://rez-auth-service.onrender.com
PAYMENT_SERVICE_URL=https://rez-payment-service.onrender.com
WALLET_SERVICE_URL=https://rez-wallet-service.onrender.com
INTENT_SERVICE_URL=https://rez-intent-graph.onrender.com

# ============================================
# CORS
# ============================================
ALLOWED_ORIGINS=https://rez.money,https://admin.rez.money,https://app.rez.money

# ============================================
# Logging
# ============================================
LOG_LEVEL=info
NODE_ENV=production

# ============================================
# Feature Flags
# ============================================
USE_NEW_INTENT_SERVICE=false
USE_NEW_COPILOT=false
USE_NEW_DECISION_SERVICE=false
USE_NEW_AD_PLATFORM=false
