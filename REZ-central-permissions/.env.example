# REZ Central Permissions - Environment Configuration

# =============================================================================
# REQUIRED VARIABLES
# =============================================================================

INTERNAL_SERVICE_TOKEN=your-secure-random-token-here
INTERNAL_SERVICE_TOKENS_JSON={"user-service":"token1","admin-service":"token2"}

# =============================================================================
# SERVER
# =============================================================================

PORT=4047
NODE_ENV=development

# =============================================================================
# REDIS CACHE
# =============================================================================

REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
CACHE_TTL_SECONDS=300

# =============================================================================
# JWT SECRET
# =============================================================================

JWT_SECRET=your-secret-key-here

# =============================================================================
# CORS (Required in production)
# =============================================================================

CORS_ORIGINS=https://rezapp.com,https://www.rezapp.com

# =============================================================================
# SECURITY NOTES
# =============================================================================
# Generate token: openssl rand -hex 32
# Never use wildcard CORS in production
