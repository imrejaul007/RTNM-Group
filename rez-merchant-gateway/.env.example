# REZ Merchant Gateway - Environment Variables

# Server
PORT=4080
NODE_ENV=development
LOG_LEVEL=info

# CORS
CORS_ORIGINS=http://localhost:3000,https://admin.rez.money,https://merchant.rez.money

# Security
JWT_SECRET=your-jwt-secret-min-64-chars-here-for-consumer-tokens
JWT_MERCHANT_SECRET=your-merchant-jwt-secret-min-64-chars
INTERNAL_SERVICE_TOKEN=your-internal-service-token
INTERNAL_SERVICE_TOKENS_JSON={"auth":"token","wallet":"token","payment":"token"}

# ===========================================
# RABTUL SERVICES
# ===========================================
AUTH_SERVICE_URL=https://rez-auth-service.onrender.com
AUTH_SERVICE_TOKEN=your-auth-service-token

WALLET_SERVICE_URL=https://rez-wallet-service.onrender.com
WALLET_SERVICE_TOKEN=your-wallet-service-token

PAYMENT_SERVICE_URL=https://rez-payment-service.onrender.com
PAYMENT_SERVICE_TOKEN=your-payment-service-token

ORDER_SERVICE_URL=https://rez-order-service.onrender.com
ORDER_SERVICE_TOKEN=your-order-service-token

CATALOG_SERVICE_URL=https://rez-catalog-service.onrender.com
CATALOG_SERVICE_TOKEN=your-catalog-service-token

NOTIFICATIONS_SERVICE_URL=https://rez-notifications-service.onrender.com
NOTIFICATIONS_SERVICE_TOKEN=your-notifications-service-token

# ===========================================
# REZ-MERCHANT
# ===========================================
MERCHANT_SERVICE_URL=https://rez-merchant-service.onrender.com
MERCHANT_SERVICE_TOKEN=your-merchant-service-token

# ===========================================
# REZ-MEDIA
# ===========================================
ENGAGEMENT_SERVICE_URL=https://rez-engagement-platform.onrender.com
ENGAGEMENT_SERVICE_TOKEN=your-engagement-service-token

MARKETING_SERVICE_URL=https://rez-marketing-service.onrender.com
MARKETING_SERVICE_TOKEN=your-marketing-service-token

LOYALTY_SERVICE_URL=https://rez-loyalty-service.onrender.com
LOYALTY_SERVICE_TOKEN=your-loyalty-service-token

# ===========================================
# REZ-INTELLIGENCE
# ===========================================
INTELLIGENCE_SERVICE_URL=https://rez-intelligence.onrender.com
INTELLIGENCE_SERVICE_TOKEN=your-intelligence-service-token

ATTRIBUTION_SERVICE_URL=https://rez-attribution.onrender.com
ATTRIBUTION_SERVICE_TOKEN=your-attribution-service-token

# ===========================================
# RTNM-DIGITAL
# ===========================================
TRUST_SERVICE_URL=https://rez-trust-platform.onrender.com
TRUST_SERVICE_TOKEN=your-trust-service-token

OPS_SERVICE_URL=https://rez-ops-center.onrender.com
OPS_SERVICE_TOKEN=your-ops-service-token

# ===========================================
# CORPPERKS
# ===========================================
CORPPERKS_SERVICE_URL=https://rez-corpperks-service.onrender.com
CORPPERKS_SERVICE_TOKEN=your-corpperks-service-token
